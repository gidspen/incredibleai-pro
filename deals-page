<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Deal Hunter — Incredible AI</title>
  <meta name="description" content="Your personalized hotel and micro resort deal scan results, powered by Gideon Spencer's buy box framework." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #080808;
      --surface:   #101010;
      --surface2:  #161616;
      --border:    rgba(255,255,255,0.07);
      --cream:     #F2EBD9;
      --cream-dim: rgba(242,235,217,0.55);
      --cream-sub: rgba(242,235,217,0.35);
      --gold:      #C9973A;
      --gold-dim:  rgba(201,151,58,0.18);
      --gold-glow: rgba(201,151,58,0.08);
      --green:     #4CAF8A;
      --green-dim: rgba(76,175,138,0.15);
      --amber:     #E8A838;
      --amber-dim: rgba(232,168,56,0.15);
      --sans:      'Outfit', system-ui, sans-serif;
      --serif:     'Cormorant Garamond', Georgia, serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--cream);
      font-family: var(--sans);
      font-weight: 300;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
      min-height: 100vh;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 999;
      opacity: 0.4;
    }

    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(120px);
      pointer-events: none;
      z-index: 0;
    }
    .orb-1 { width: 600px; height: 600px; top: -200px; left: -150px; background: rgba(201,151,58,0.06); }
    .orb-2 { width: 400px; height: 400px; bottom: 10%; right: -100px; background: rgba(76,175,138,0.04); }

    /* ── LAYOUT ─────────────────────────────────────────────── */
    .page-wrap {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px 80px;
    }

    /* ── NAV ─────────────────────────────────────────────────── */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 28px 0 40px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 48px;
    }

    .nav-logo {
      font-family: var(--serif);
      font-size: 1.4rem;
      font-weight: 400;
      color: var(--cream);
      text-decoration: none;
      letter-spacing: 0.02em;
    }

    .nav-logo span { color: var(--gold); }

    .nav-badge {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      background: var(--gold-dim);
      border: 1px solid rgba(201,151,58,0.25);
      padding: 4px 12px;
      border-radius: 100px;
    }

    /* ── HEADER ──────────────────────────────────────────────── */
    .page-header {
      margin-bottom: 40px;
    }

    .page-header h1 {
      font-family: var(--serif);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 400;
      line-height: 1.15;
      color: var(--cream);
      margin-bottom: 12px;
    }

    .page-header h1 em {
      font-style: italic;
      color: var(--gold);
    }

    .page-header p {
      font-size: 0.95rem;
      color: var(--cream-dim);
      max-width: 560px;
    }

    /* ── EMAIL GATE ──────────────────────────────────────────── */
    #email-gate {
      display: none;
      max-width: 520px;
      margin: 80px auto;
      text-align: center;
    }

    #email-gate h2 {
      font-family: var(--serif);
      font-size: 2rem;
      font-weight: 400;
      margin-bottom: 12px;
    }

    #email-gate p {
      color: var(--cream-dim);
      font-size: 0.9rem;
      margin-bottom: 28px;
    }

    .email-form {
      display: flex;
      gap: 10px;
      justify-content: center;
    }

    .email-form input {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--cream);
      padding: 12px 16px;
      border-radius: 8px;
      font-family: var(--sans);
      font-size: 0.9rem;
      width: 260px;
      outline: none;
    }

    .email-form input:focus { border-color: var(--gold); }

    .btn-gold {
      background: var(--gold);
      color: #080808;
      border: none;
      padding: 12px 20px;
      border-radius: 8px;
      font-family: var(--sans);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      cursor: pointer;
      white-space: nowrap;
    }

    .btn-gold:hover { opacity: 0.88; }

    /* ── STATS BAR ───────────────────────────────────────────── */
    #stats-bar {
      display: none;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 48px;
    }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px 24px;
      text-align: center;
    }

    .stat-num {
      font-family: var(--serif);
      font-size: 2.4rem;
      font-weight: 400;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 4px;
    }

    .stat-label {
      font-size: 0.78rem;
      font-weight: 400;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--cream-sub);
    }

    /* ── SECTION LABELS ──────────────────────────────────────── */
    .section-label {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── DEAL CARD ───────────────────────────────────────────── */
    #top-deals { display: none; margin-bottom: 56px; }
    #all-deals  { display: none; margin-bottom: 56px; }

    .deals-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
    }

    .deal-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 24px;
      position: relative;
      transition: border-color 0.2s;
    }

    .deal-card:hover { border-color: rgba(201,151,58,0.3); }

    .deal-card.top-pick {
      border-color: rgba(201,151,58,0.4);
      background: linear-gradient(135deg, var(--surface) 0%, rgba(201,151,58,0.04) 100%);
    }

    .top-pick-badge {
      position: absolute;
      top: 16px;
      right: 16px;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      background: var(--gold-dim);
      border: 1px solid rgba(201,151,58,0.3);
      padding: 3px 10px;
      border-radius: 100px;
    }

    .deal-type {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--cream-sub);
      margin-bottom: 8px;
    }

    .deal-name {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 500;
      color: var(--cream);
      margin-bottom: 4px;
      line-height: 1.25;
      padding-right: 70px;
    }

    .deal-location {
      font-size: 0.85rem;
      color: var(--cream-dim);
      margin-bottom: 16px;
    }

    .deal-meta {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    .deal-meta-item {
      font-size: 0.8rem;
      color: var(--cream-dim);
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 4px 10px;
      border-radius: 6px;
    }

    .deal-meta-item strong {
      color: var(--cream);
      font-weight: 500;
    }

    /* ── SCORECARD BARS ──────────────────────────────────────── */
    .scorecard {
      display: flex;
      gap: 6px;
      margin-bottom: 16px;
      align-items: center;
    }

    .score-pill {
      font-size: 0.72rem;
      font-weight: 500;
      padding: 4px 10px;
      border-radius: 100px;
      white-space: nowrap;
    }

    .score-pill.pass {
      background: var(--green-dim);
      color: var(--green);
      border: 1px solid rgba(76,175,138,0.25);
    }

    .score-pill.flag {
      background: var(--amber-dim);
      color: var(--amber);
      border: 1px solid rgba(232,168,56,0.25);
    }

    .score-pill.uncertain {
      background: rgba(255,255,255,0.06);
      color: var(--cream-dim);
      border: 1px solid var(--border);
    }

    /* ── NEXT STEP ───────────────────────────────────────────── */
    .deal-next-step {
      background: var(--gold-glow);
      border: 1px solid rgba(201,151,58,0.15);
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 0.82rem;
      color: var(--cream-dim);
      line-height: 1.5;
    }

    .deal-next-step strong {
      display: block;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 4px;
    }

    /* ── ELIMINATED TABLE ────────────────────────────────────── */
    #screened-out { display: none; }

    .screened-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.84rem;
    }

    .screened-table th {
      text-align: left;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--cream-sub);
      padding: 10px 12px;
      border-bottom: 1px solid var(--border);
    }

    .screened-table td {
      padding: 10px 12px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      color: var(--cream-dim);
      vertical-align: top;
    }

    .screened-table tr:hover td { background: rgba(255,255,255,0.02); }

    .gate-tag {
      font-size: 0.7rem;
      font-weight: 500;
      padding: 2px 8px;
      border-radius: 4px;
      background: rgba(255,255,255,0.06);
      color: var(--cream-sub);
      white-space: nowrap;
    }

    /* ── EMPTY / LOADING STATES ──────────────────────────────── */
    #loading {
      text-align: center;
      padding: 80px 24px;
      color: var(--cream-sub);
      font-size: 0.9rem;
    }

    .spinner {
      width: 28px;
      height: 28px;
      border: 2px solid var(--border);
      border-top-color: var(--gold);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 16px;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .empty-state {
      text-align: center;
      padding: 60px 24px;
      color: var(--cream-sub);
    }

    .empty-state h3 {
      font-family: var(--serif);
      font-size: 1.5rem;
      font-weight: 400;
      color: var(--cream-dim);
      margin-bottom: 8px;
    }

    .empty-state p { font-size: 0.88rem; }

    /* ── SHOW MORE ───────────────────────────────────────────── */
    .show-more-wrap { text-align: center; margin-top: 24px; }

    .btn-ghost {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--cream-dim);
      padding: 10px 20px;
      border-radius: 8px;
      font-family: var(--sans);
      font-size: 0.82rem;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
    }

    .btn-ghost:hover { border-color: var(--gold); color: var(--cream); }

    /* ── FOOTER ──────────────────────────────────────────────── */
    footer {
      text-align: center;
      padding-top: 40px;
      border-top: 1px solid var(--border);
      margin-top: 24px;
      font-size: 0.78rem;
      color: var(--cream-sub);
    }

    footer a { color: var(--cream-sub); text-decoration: none; }
    footer a:hover { color: var(--gold); }

    /* ── RESPONSIVE ──────────────────────────────────────────── */
    @media (max-width: 640px) {
      #stats-bar { grid-template-columns: repeat(3, 1fr); gap: 10px; }
      .stat-num { font-size: 1.8rem; }
      .deals-grid { grid-template-columns: 1fr; }
      .email-form { flex-direction: column; align-items: stretch; }
      .email-form input { width: 100%; }
    }
  </style>
</head>
<body>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>

  <div class="page-wrap">
    <nav>
      <a href="/" class="nav-logo">Incredible <span>AI</span></a>
      <span class="nav-badge">Deal Hunter</span>
    </nav>

    <div class="page-header">
      <h1>Your <em>deal scan</em><br>results</h1>
      <p>Gideon Spencer's buy box framework, applied to your search. Every property screened. The ones worth investigating, surfaced.</p>
    </div>

    <!-- Loading -->
    <div id="loading">
      <div class="spinner"></div>
      <p>Loading your scan results...</p>
    </div>

    <!-- Email gate (shown if no ?email param) -->
    <div id="email-gate">
      <h2>Enter your email<br>to view results</h2>
      <p>Results are tied to the email you provided during your deal scan.</p>
      <form class="email-form" onsubmit="handleEmailSubmit(event)">
        <input type="email" id="gate-email" placeholder="your@email.com" required autocomplete="email" />
        <button type="submit" class="btn-gold">View Results</button>
      </form>
    </div>

    <!-- Stats bar -->
    <div id="stats-bar">
      <div class="stat-card">
        <div class="stat-num" id="stat-scanned">—</div>
        <div class="stat-label">Listings Scanned</div>
      </div>
      <div class="stat-card">
        <div class="stat-num" id="stat-eliminated">—</div>
        <div class="stat-label">Eliminated</div>
      </div>
      <div class="stat-card">
        <div class="stat-num" id="stat-survivors">—</div>
        <div class="stat-label">Worth Investigating</div>
      </div>
    </div>

    <!-- Top deals -->
    <div id="top-deals">
      <div class="section-label">Top Picks</div>
      <div class="deals-grid" id="top-deals-grid"></div>
    </div>

    <!-- All surviving deals -->
    <div id="all-deals">
      <div class="section-label">All Survivors</div>
      <div class="deals-grid" id="all-deals-grid"></div>
    </div>

    <!-- Screened out -->
    <div id="screened-out">
      <div class="section-label">Screened Out</div>
      <div id="screened-summary" style="margin-bottom:16px; font-size:0.85rem; color:var(--cream-dim);"></div>
      <table class="screened-table" id="screened-table">
        <thead>
          <tr>
            <th>Property</th>
            <th>Location</th>
            <th>Gate Failed</th>
            <th>Reason</th>
          </tr>
        </thead>
        <tbody id="screened-tbody"></tbody>
      </table>
      <div class="show-more-wrap" id="screened-show-more" style="display:none;">
        <button class="btn-ghost" onclick="showAllScreened()">Show all eliminated deals</button>
      </div>
    </div>

    <!-- Empty state (no results yet) -->
    <div id="empty-state" style="display:none;">
      <div class="empty-state">
        <h3>No scan results yet</h3>
        <p>Run a deal scan in Claude to see your results here. Type <strong>deal-hunter</strong> to get started.</p>
      </div>
    </div>

    <footer>
      <p>Powered by <a href="/">Incredible AI</a> &nbsp;·&nbsp; Framework by <a href="https://instagram.com/gideonspencer_" target="_blank">Gideon Spencer</a></p>
    </footer>
  </div>

  <script>
    const SUPABASE_URL = 'https://faxphgxpshbqpdwnxyey.supabase.co';
    const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZheHBoZ3hwc2hicXBkd254eWV5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4MTU3NjIsImV4cCI6MjA5MDM5MTc2Mn0.USzidFiTfINRRuZpQWbXElDHigXXqF4dVjDQ7j9vgDw';

    let allScreened = [];
    let screenedShowing = 20;

    async function supabase(path, params) {
      const url = new URL(SUPABASE_URL + '/rest/v1/' + path);
      if (params) Object.entries(params).forEach(([k,v]) => url.searchParams.set(k, v));
      const r = await fetch(url, {
        headers: {
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
          'Accept': 'application/json'
        }
      });
      if (!r.ok) throw new Error('Supabase error: ' + r.status);
      return r.json();
    }

    function fmt(val, prefix='', suffix='') {
      if (val == null) return '—';
      return prefix + val.toLocaleString() + suffix;
    }

    function statusPill(status, label) {
      const cls = status === 'PASS' ? 'pass' : status === 'FLAG' ? 'flag' : 'uncertain';
      const icon = status === 'PASS' ? '✅' : '⚠️';
      return `<span class="score-pill ${cls}">${icon} ${label || status}</span>`;
    }

    function renderDealCard(deal) {
      const isTop = deal.is_top_pick;
      const typeLabel = deal.asset_type === 'hotel' ? 'Hotel · Wealth Building' :
                        deal.asset_type === 'micro_resort' ? 'Micro Resort · Cash Flow' : 'Mixed Strategy';

      const passes = deal.flags_count != null && deal.uncertainties_count != null
        ? (deal.criteria_count || 0) - deal.flags_count - deal.uncertainties_count
        : null;

      return `
        <div class="deal-card${isTop ? ' top-pick' : ''}">
          ${isTop ? '<div class="top-pick-badge">Top Pick</div>' : ''}
          <div class="deal-type">${typeLabel}</div>
          <div class="deal-name">${deal.name || 'Unnamed Property'}</div>
          <div class="deal-location">${deal.location || '—'}</div>
          <div class="deal-meta">
            ${deal.price ? `<div class="deal-meta-item"><strong>${fmt(deal.price, '$')}</strong></div>` : ''}
            ${deal.keys ? `<div class="deal-meta-item"><strong>${deal.keys}</strong> keys</div>` : ''}
            ${deal.flags_count != null ? `<div class="deal-meta-item"><strong>${deal.flags_count}</strong> flags</div>` : ''}
            ${deal.uncertainties_count != null ? `<div class="deal-meta-item"><strong>${deal.uncertainties_count}</strong> to verify</div>` : ''}
          </div>
          ${passes != null || deal.flags_count || deal.uncertainties_count ? `
          <div class="scorecard">
            ${passes ? statusPill('PASS', `${passes} Pass`) : ''}
            ${deal.flags_count ? statusPill('FLAG', `${deal.flags_count} Flag`) : ''}
            ${deal.uncertainties_count ? statusPill('UNCERTAIN', `${deal.uncertainties_count} Uncertain`) : ''}
          </div>` : ''}
          ${deal.next_step ? `
          <div class="deal-next-step">
            <strong>Next Step</strong>
            ${deal.next_step}
          </div>` : ''}
        </div>`;
    }

    function renderScreenedRow(item) {
      const gateLabel = {
        'key_count': 'Key Count',
        'drive_market': 'Drive Market',
        'asset_type': 'Asset Type',
        'price': 'Price'
      }[item.elimination_gate] || item.elimination_gate || '—';

      return `<tr>
        <td style="color:var(--cream)">${item.name || '—'}</td>
        <td>${item.location || '—'}</td>
        <td><span class="gate-tag">${gateLabel}</span></td>
        <td>${item.elimination_reason || '—'}</td>
      </tr>`;
    }

    function showAllScreened() {
      const tbody = document.getElementById('screened-tbody');
      tbody.innerHTML = allScreened.map(renderScreenedRow).join('');
      document.getElementById('screened-show-more').style.display = 'none';
    }

    async function loadResults(email) {
      try {
        // Get the most recent search for this email
        const searches = await supabase('deal_searches', {
          'user_email': `eq.${email}`,
          'order': 'created_at.desc',
          'limit': '1',
          'select': '*'
        });

        if (!searches || searches.length === 0) {
          document.getElementById('loading').style.display = 'none';
          document.getElementById('empty-state').style.display = 'block';
          return;
        }

        const search = searches[0];

        // Stats
        document.getElementById('stat-scanned').textContent = (search.total_scanned || 0).toLocaleString();
        document.getElementById('stat-eliminated').textContent = (search.screened_out || 0).toLocaleString();
        document.getElementById('stat-survivors').textContent = (search.survivors || 0).toLocaleString();
        document.getElementById('stats-bar').style.display = 'grid';

        // Surviving deals
        const properties = await supabase('deal_properties', {
          'search_id': `eq.${search.id}`,
          'order': 'is_top_pick.desc,flags_count.asc',
          'select': '*'
        });

        const topPicks = (properties || []).filter(p => p.is_top_pick);
        const allSurvivors = properties || [];

        if (topPicks.length > 0) {
          document.getElementById('top-deals-grid').innerHTML = topPicks.map(renderDealCard).join('');
          document.getElementById('top-deals').style.display = 'block';
        }

        if (allSurvivors.length > 0 && topPicks.length !== allSurvivors.length) {
          const nonTop = allSurvivors.filter(p => !p.is_top_pick);
          if (nonTop.length > 0) {
            document.getElementById('all-deals-grid').innerHTML = nonTop.map(renderDealCard).join('');
            document.getElementById('all-deals').style.display = 'block';
          }
        } else if (allSurvivors.length > 0 && topPicks.length === 0) {
          document.getElementById('all-deals-grid').innerHTML = allSurvivors.map(renderDealCard).join('');
          document.getElementById('all-deals').style.display = 'block';
        }

        // Screened out
        const screened = await supabase('deal_screened', {
          'search_id': `eq.${search.id}`,
          'order': 'created_at.asc',
          'select': '*'
        });

        if (screened && screened.length > 0) {
          allScreened = screened;

          // Elimination summary
          const reasons = search.eliminated_reasons || {};
          const parts = [];
          if (reasons.key_count) parts.push(`${reasons.key_count} failed key count`);
          if (reasons.drive_market) parts.push(`${reasons.drive_market} failed drive market`);
          if (reasons.asset_type) parts.push(`${reasons.asset_type} wrong asset type`);
          if (reasons.price) parts.push(`${reasons.price} over budget`);
          if (parts.length > 0) {
            document.getElementById('screened-summary').textContent = parts.join(' · ');
          }

          const firstBatch = screened.slice(0, screenedShowing);
          document.getElementById('screened-tbody').innerHTML = firstBatch.map(renderScreenedRow).join('');
          document.getElementById('screened-out').style.display = 'block';

          if (screened.length > screenedShowing) {
            document.getElementById('screened-show-more').style.display = 'block';
          }
        }

        if (allSurvivors.length === 0 && (!screened || screened.length === 0)) {
          document.getElementById('empty-state').style.display = 'block';
        }

        document.getElementById('loading').style.display = 'none';

      } catch (err) {
        console.error(err);
        document.getElementById('loading').innerHTML = '<p style="color:var(--cream-sub)">Could not load results. Please try refreshing.</p>';
      }
    }

    function handleEmailSubmit(e) {
      e.preventDefault();
      const email = document.getElementById('gate-email').value.trim();
      if (!email) return;
      sessionStorage.setItem('deal_hunter_email', email);
      document.getElementById('email-gate').style.display = 'none';
      document.getElementById('loading').style.display = 'block';
      loadResults(email);
    }

    // Init
    (function init() {
      const params = new URLSearchParams(window.location.search);
      const urlEmail = params.get('email');
      const storedEmail = sessionStorage.getItem('deal_hunter_email');
      const email = urlEmail || storedEmail;

      if (email) {
        loadResults(email);
      } else {
        document.getElementById('loading').style.display = 'none';
        document.getElementById('email-gate').style.display = 'block';
      }
    })();
  </script>
</body>
</html>
